#!/usr/bin/env python

import pathlib
import shutil
import argparse
import sys

zshrc = pathlib.Path.home() / ".zshrc"
zsh_config = pathlib.Path.home() / ".config" / "zsh"
zinit = pathlib.Path.home() / ".local" / "share" / "zinit"


def delete_path(path):
    try:
        if path.is_file():
            path.unlink()
            print(f"{path.name} deleted")
        elif path.is_dir():
            shutil.rmtree(path)
            print(f"{path.name} deleted")
        else:
            print(f"{path.name} not found")
    except Exception as e:
        print(f"Error deleting {path.name}: {e}")
        sys.exit(1)


def main():
    delete_path(zshrc)
    delete_path(zinit)
    delete_path(zsh_config)

    print("\n\nSuccess!!! All files and directories deleted!!!")


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Delete .zshrc, zinit, and zsh config")
    parser.add_argument(
        "-y", "--yes", action="store_true", help="Skip confirmation prompt"
    )
    args = parser.parse_args()

        if args.yes:
            main()
        else:
            inp = input("Are you sure? [y/N] ").strip().lower()
            if inp == "y":
                main()
            else:
                print("Aborted")
        sys.exit(1)
